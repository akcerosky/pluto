{
  "name": "pluto-functions",
  "private": true,
  "version": "1.0.0",
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "if exist lib rmdir /s /q lib",
    "serve": "firebase emulators:start --only functions,firestore,auth",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "set-admin": "tsx src/scripts/setAdminClaims.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.24.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^7.2.5",
    "razorpay": "^2.9.6",
    "resend": "^6.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
