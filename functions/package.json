{
  "name": "pluto-functions",
  "private": true,
  "version": "1.0.0",
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "if exist lib rmdir /s /q lib",
    "serve": "firebase emulators:start --only functions,firestore,auth",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "set-admin": "tsx src/scripts/setAdminClaims.ts",
    "test": "tsx --test src/services/gemini.test.ts src/services/razorpay.test.ts src/handlers/http.test.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.4.0",
    "razorpay": "^2.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
