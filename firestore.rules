rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/appState/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/threads/{threadId} {
      allow read, write: if isOwner(userId);

      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId}/projects/{projectId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/questionPapers/{paperId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/flashcardSets/{setId} {
      allow read, write: if isOwner(userId);

      match /cards/{cardId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId}/flashcardSessions/{sessionId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/meta/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/subscriptionPublic/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/profile/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/usageDaily/{document=**} {
      allow read, write: if false;
    }

    match /users/{userId}/payments/{document=**} {
      allow read, write: if false;
    }

    match /users/{userId}/subscriptionPrivate/{document=**} {
      allow read, write: if false;
    }

    match /users/{userId}/billingEvents/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
